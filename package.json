{
  "name": "antigravity-conversation-manager",
  "displayName": "Conversation Manager",
  "description": "Manage multiple AI conversations with tabs in the Antigravity sidebar",
  "version": "0.2.0",
  "publisher": "florian",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conversationManager",
          "title": "Conversations",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "conversationManager": [
        {
          "type": "webview",
          "id": "conversationManager.webviewList",
          "name": "Conversations",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "conversationManager.newConversation",
        "title": "New Conversation",
        "category": "Conversations",
        "icon": "$(add)"
      },
      {
        "command": "conversationManager.openPicker",
        "title": "Open Conversation Picker",
        "category": "Conversations",
        "icon": "$(search)"
      },
      {
        "command": "conversationManager.switchTo",
        "title": "Switch to Conversation",
        "category": "Conversations",
        "icon": "$(arrow-right)"
      },
      {
        "command": "conversationManager.rename",
        "title": "Rename",
        "category": "Conversations",
        "icon": "$(edit)"
      },
      {
        "command": "conversationManager.pin",
        "title": "Pin",
        "category": "Conversations",
        "icon": "$(pin)"
      },
      {
        "command": "conversationManager.unpin",
        "title": "Unpin",
        "category": "Conversations",
        "icon": "$(pinned)"
      },
      {
        "command": "conversationManager.deleteConversation",
        "title": "Delete",
        "category": "Conversations",
        "icon": "$(trash)"
      },
      {
        "command": "conversationManager.refresh",
        "title": "Refresh",
        "category": "Conversations",
        "icon": "$(refresh)"
      },
      {
        "command": "conversationManager.copyId",
        "title": "Copy Conversation ID",
        "category": "Conversations",
        "icon": "$(clippy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "conversationManager.newConversation",
          "when": "view == conversationManager.pinnedList || view == conversationManager.recentList",
          "group": "navigation@1"
        },
        {
          "command": "conversationManager.openPicker",
          "when": "view == conversationManager.pinnedList || view == conversationManager.recentList",
          "group": "navigation@2"
        },
        {
          "command": "conversationManager.refresh",
          "when": "view == conversationManager.pinnedList || view == conversationManager.recentList",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "conversationManager.switchTo",
          "when": "view == conversationManager.recentList || view == conversationManager.pinnedList",
          "group": "inline@1"
        },
        {
          "command": "conversationManager.rename",
          "when": "view == conversationManager.recentList || view == conversationManager.pinnedList",
          "group": "1_actions@1"
        },
        {
          "command": "conversationManager.pin",
          "when": "viewItem == conversation && (view == conversationManager.recentList)",
          "group": "1_actions@2"
        },
        {
          "command": "conversationManager.unpin",
          "when": "viewItem == pinnedConversation && (view == conversationManager.pinnedList)",
          "group": "1_actions@2"
        },
        {
          "command": "conversationManager.copyId",
          "when": "view == conversationManager.recentList || view == conversationManager.pinnedList",
          "group": "2_info@1"
        },
        {
          "command": "conversationManager.deleteConversation",
          "when": "view == conversationManager.recentList || view == conversationManager.pinnedList",
          "group": "3_danger@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "conversationManager.newConversation",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      },
      {
        "command": "conversationManager.openPicker",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      }
    ],
    "configuration": {
      "title": "Conversation Manager",
      "properties": {}
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile",
    "deploy": "npm run compile && ./scripts/deploy.sh"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
